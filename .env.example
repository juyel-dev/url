# Frontend Application Configuration
VITE_APP_NAME=URL Shortener
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Production-grade URL shortening platform
VITE_APP_URL=https://url.vercel.app

# Google Apps Script Backend Configuration
VITE_GAS_API_ENDPOINT=https://script.google.com/macros/d/{YOUR_DEPLOYMENT_ID}/usercodeapp
VITE_GAS_DEPLOYMENT_ID={YOUR_DEPLOYMENT_ID}

# Google Sheets Configuration
VITE_GOOGLE_SHEET_ID={YOUR_SPREADSHEET_ID}
VITE_GOOGLE_SHEET_TAB_LINKS=Links
VITE_GOOGLE_SHEET_TAB_ANALYTICS=Analytics
VITE_GOOGLE_SHEET_TAB_SETTINGS=User Settings
VITE_GOOGLE_SHEET_TAB_AUDIT=Audit Log
VITE_GOOGLE_SHEET_TAB_EXPORT=CSV Export Queue

# CSV Cache Configuration
VITE_CSV_CACHE_UPDATE_INTERVAL=300000
VITE_CSV_SYNC_ENABLED=true
VITE_CSV_FALLBACK_URL=https://drive.google.com/uc?export=download&id={YOUR_CSV_FILE_ID}

# Feature Flags
VITE_ENABLE_PASSWORD_PROTECTION=true
VITE_ENABLE_EXPIRATION_DATE=true
VITE_ENABLE_CUSTOM_SLUG=true
VITE_ENABLE_QR_CODE=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DARK_MODE=false

# Analytics & Monitoring
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_ANALYTICS_ENABLED=false

# Security Configuration
VITE_HASH_ALGORITHM=SHA256
VITE_MAX_URL_LENGTH=2048
VITE_MAX_SLUG_LENGTH=32
VITE_MIN_SLUG_LENGTH=3
VITE_MAX_CUSTOM_SLUGS_PER_DAY=100
VITE_PASSWORD_MIN_LENGTH=4
VITE_PASSWORD_MAX_LENGTH=64
VITE_RATE_LIMIT_REQUESTS_PER_MINUTE=30

# Storage Configuration
VITE_LOCALSTORAGE_KEY_PREFIX=url_shortener_
VITE_MAX_HISTORY_ITEMS=10
VITE_STORAGE_QUOTA_WARNING_THRESHOLD=80

# UI Configuration
VITE_ANIMATION_DURATION=300
VITE_TOAST_DURATION=3000
VITE_LOADING_ANIMATION_ENABLED=true
VITE_GLASS_MORPHISM_ENABLED=true
VITE_DARK_MODE_AUTO=true

# Vercel Deployment Configuration
VITE_VERCEL_PROJECT_NAME=url
VITE_VERCEL_ORG_SLUG=juyel-dev
VITE_VERCEL_DEPLOYMENT_URL=url.vercel.app

# Premium & Monetization
VITE_PREMIUM_ENABLED=false
VITE_DONATION_ENABLED=true
VITE_RAZORPAY_KEY_ID=
VITE_UPI_PAYMENT_ENABLED=true
VITE_PREMIUM_PRICE_INR=99

# Development Configuration
VITE_LOG_LEVEL=info
VITE_DEBUG_MODE=false
VITE_API_TIMEOUT=10000
VITE_DEVELOPMENT_SERVER_PORT=5173
