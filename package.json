{
  "name": "url-shortener",
  "version": "1.0.0",
  "description": "Production-grade URL shortening platform with custom aliases, password protection, and instant QR codes",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "framer-motion": "^10.16.16",
    "qrcode.react": "^1.0.1",
    "axios": "^1.6.7",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "clsx": "^2.0.0",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.10.6",
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.8",
    "typescript": "^5.3.3",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react": "^7.33.2",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "prettier": "^3.1.1",
    "vitest": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.1.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "url-shortener",
    "link-shortening",
    "qr-code",
    "custom-alias",
    "password-protection",
    "analytics",
    "react",
    "typescript",
    "tailwind"
  ],
  "author": "juyel-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/juyel-dev/url.git"
  },
  "homepage": "https://url.vercel.app",
  "bugs": {
    "url": "https://github.com/juyel-dev/url/issues"
  }
}
